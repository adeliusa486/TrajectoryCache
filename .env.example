# ── TrajectoryCache environment variables ─────────────────────────────────
# Copy this file to .env and adjust values.

# API
TC_API_HOST=0.0.0.0
TC_API_PORT=8000
TC_LOG_LEVEL=INFO

# Simulation overrides (prefix TC_ maps to SimulationConfig field)
# TC_N_VEHICLES=50
# TC_N_STEPS=1000
# TC_SEED=42
# TC_CACHE_CAPACITY=20

# Results output directory
TC_RESULTS_DIR=experiments/results
